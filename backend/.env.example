# Backend-only secrets. Do not expose these to the frontend.
# At least one model provider key enables real AI output. With none set, the app
# still runs and falls back to deterministic templates.

# OpenAI (default provider for now).
OPENAI_API_KEY=

# Groq — fast, cheap open models (Llama, etc.). Activates automatically when set.
GROQ_API_KEY=

# Anthropic (Claude) — for higher-judgment work later. Optional.
ANTHROPIC_API_KEY=

# Optional: override the model used per provider (defaults shown).
# OPENAI_MODEL=gpt-4.1-mini
# GROQ_MODEL=llama-3.3-70b-versatile   # set to a current Groq model id
# ANTHROPIC_MODEL=claude-sonnet-5

# Required for live internet market research.
TAVILY_API_KEY=

# Frontend origin allowed by CORS during local development.
FRONTEND_ORIGIN=http://127.0.0.1:3000

# Required for INR 99 paid blueprint checkout.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
